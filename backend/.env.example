# KnowAll Studio - Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=KnowAll Studio
APP_VERSION=0.1.0
DEBUG=true

# Database — use MySQL (sensitive data stays on server, NEVER in git)
DATABASE_URL=mysql+asyncmy://user:password@localhost:3306/knowall?charset=utf8mb4
# SQLite fallback (local dev only, DO NOT use for sensitive data):
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Vector Database
CHROMA_PERSIST_DIR=./data/vector_db
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# API Keys (fill at least one)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Local Ollama (no API key needed, install Ollama first)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Rate Limiting
MAX_CONCURRENT_REQUESTS=5
DAILY_TOKEN_LIMIT=1000000

# File Storage
MAX_UPLOAD_SIZE_MB=100
CHUNK_SIZE_TOKENS=2000
CHUNK_OVERLAP_RATIO=0.1

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","app://."]

# Docling Document Parsing (structure-aware PDF/DOCX/PPTX)
USE_DOCLING=true
DOCLING_OCR=false
DOCLING_OCR_LANG=chi_sim+eng

# Native Outline (instant, no LLM calls)
NATIVE_OUTLINE_ENABLED=true
NATIVE_OUTLINE_MAX_DEPTH=4

# Vision Analysis (image → text via vision-capable LLM, disabled by default)
VISION_ANALYSIS_ENABLED=false
VISION_MODEL=gpt-4o
VISION_MAX_IMAGES=8
VISION_MIN_IMAGE_DIMENSION=100
